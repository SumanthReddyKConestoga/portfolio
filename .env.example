# Public site URL (used for canonical URLs, sitemap, and Open Graph metadata)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Web3Forms access key (free at https://web3forms.com) — powers the contact form.
# Public by design; safe to expose in the browser. Leave empty to disable the form
# (the section falls back to direct email / LinkedIn buttons).
NEXT_PUBLIC_WEB3FORMS_KEY=
